{
  "permissions": {
    "allow": [
      "Bash(curl -s http://localhost:3000/*)",
      "Bash(lsof -i :3000 *)",
      "Bash(npm test)",
      "Bash(npx tsc --noEmit)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hook-tsc.sh",
            "timeout": 30,
            "statusMessage": "型チェック中..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'rm -rf' && echo '{\"decision\":\"block\",\"reason\":\"rm -rf は安全のためブロックされています\"}' && exit 2 || true",
            "timeout": 10,
            "statusMessage": "コマンドを検証中..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "todo-api-tester|todo-api-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hook-subagent-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hook-stop-test.sh",
            "timeout": 30,
            "statusMessage": "最終テスト実行中..."
          }
        ]
      }
    ]
  }
}
